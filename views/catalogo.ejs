        <!-- Lado Izquierdo: Imagen Completa -->
        <div class="w-full md:w-1/2 h-64 md:h-auto bg-slate-50 relative">
            <img id="det-imagen" src="" alt="" class="w-full h-full object-cover">
            <span id="det-categoria" class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm text-pink-600 text-[10px] font-black uppercase tracking-wider px-2.5 py-1 rounded-md shadow-sm border border-pink-50"></span>
        </div>

        <!-- Lado Derecho: Textos y Datos -->
        <div class="w-full md:w-1/2 p-6 flex flex-col justify-between bg-white relative">
            <!-- Botón Cerrar para Computadora -->
            <button onclick="cerrarModalDetalle()" class="absolute top-4 right-4 text-slate-400 hover:text-slate-600 text-sm font-bold hidden md:block bg-slate-100 px-2.5 py-1 rounded-lg transition">Cerrar ✕</button>
            
            <div class="mt-4 md:mt-6 flex-grow">
                <h3 id="det-nombre" class="font-black text-slate-900 text-2xl tracking-tight leading-tight"></h3>
                <div id="det-precio" class="text-2xl font-black text-pink-600 mt-2"></div>
                
                <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mt-6 mb-1">Descripción del producto:</h4>
                <p id="det-descripcion" class="text-slate-600 text-sm leading-relaxed overflow-y-auto max-h-[180px] pr-1 no-scrollbar"></p>
            </div>

            <!-- Acción de Compra -->
            <div class="pt-6 border-t border-slate-100 mt-4 flex gap-2" id="det-contenedor-boton">
                <!-- Se inyectará el botón dinámicamente vía JS -->
            </div>
        </div>

    </div>
</div>


</body>
</html>

