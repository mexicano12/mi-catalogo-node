<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kilyad CREACIONES</title>
    <!-- Tailwind CSS Oficial -->
    <script src="https://cdn.tailwindcss.com"></script>
        <!-- Inyección prioritaria de funciones para los Modales -->
    <script>
        function abrirModalDetalle(id, nombre, descripcion, precio, imagenUrl, categoria) {
            const modal = document.getElementById('modal-detalle');
            if (!modal) return;
            
            document.getElementById('det-imagen').src = imagenUrl;
            document.getElementById('det-imagen').alt = nombre;
            document.getElementById('det-nombre').innerText = nombre;
            document.getElementById('det-categoria').innerText = categoria;
            document.getElementById('det-precio').innerText = `$${precio.toFixed(2)}`;
            document.getElementById('det-descripcion').innerText = descripcion;

            document.getElementById('det-contenedor-boton').innerHTML = `
                <button onclick="agregarAlCarrito(${id}, '${nombre.replace(/'/g, "\\'")}', ${precio}, '${imagenUrl}'); cerrarModalDetalle();" class="w-full bg-pink-600 text-white py-3 rounded-xl font-bold hover:bg-pink-700 transition flex items-center justify-center gap-2 shadow-md active:scale-95">
                    <span>Añadir al Carrito</span> <span>🛒</span>
                </button>
            `;
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function cerrarModalDetalle() {
            const modal = document.getElementById('modal-detalle');
            if (modal) {
                modal.classList.remove('flex');
                modal.classList.add('hidden');
            }
        }
    </script>

</head>
<body class="bg-slate-50 text-slate-800 font-sans">

