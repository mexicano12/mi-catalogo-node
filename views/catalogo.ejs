    <!-- ================= SCRIPT PARA MOVER EL CARRUSEL AUTOMÁTICAMENTE ================= -->
       <!-- ================= SCRIPT PARA MOVER EL CARRUSEL AUTOMÁTICAMENTE ================= -->
    <script>
        let currentSlide = 1;
        
        function cambiarSlide(num) {
            currentSlide = num;
            for (let i = 1; i <= 3; i++) {
                const slide = document.getElementById(`slide-${i}`);
                const dot = document.getElementById(`dot-${i}`);
                if (i === num) {
                    if (slide) {
                        slide.classList.remove('opacity-0');
                        slide.classList.add('opacity-100');
                    }
                    if (dot) {
                        dot.classList.remove('bg-white/40');
                        dot.classList.add('bg-white');
                    }
                } else {
                    if (slide) {
                        slide.classList.remove('opacity-100');
                        slide.classList.add('opacity-0');
                    }
                    if (dot) {
                        dot.classList.remove('bg-white');
                        dot.classList.add('bg-white/40');
                    }
                }
            }
        }

        // Carrusel automático cada 4 segundos
        setInterval(() => {
            currentSlide = currentSlide === 3 ? 1 : currentSlide + 1;
            cambiarSlide(currentSlide);
        }, 4000);
    </script>
  
<!-- ================= LÓGICA INTERACTIVA COMPLETA DEL CARRITO ================= -->
<script>
    // Inicializamos el carrito leyendo la Mac del cliente
    let carrito = JSON.parse(localStorage.getItem('trendy_carrito')) || [];
    actualizarGloboCarrito();

        function agregarAlCarrito(id, nombre, precio, imagenUrl) {
        // ＋ PASO 1: Ahora la función ya acepta el cuarto parámetro (imagenUrl)
        const productoExistente = carrito.find(item => item.id === id);
        
        if (productoExistente) {
            productoExistente.cantidad += 1;
        } else {
            // ＋ PASO 2: Aquí ya guardamos de forma obligatoria la ruta de la foto en la memoria
            const fotoFinal = (imagenUrl && imagenUrl !== 'undefined') ? imagenUrl : '/logo2.png';
            carrito.push({ id, nombre, precio, imagenUrl: fotoFinal, cantidad: 1 });
        }
        guardarCarritoYActualizar();
    }


    function guardarCarritoYActualizar() {
        localStorage.setItem('trendy_carrito', JSON.stringify(carrito));
        actualizarGloboCarrito();
        if (!document.getElementById('modal-carrito').classList.contains('hidden')) {
            renderizarItemsCarrito();
        }
    }

    function actualizarGloboCarrito() {
        const contador = document.getElementById('contador-carrito');
        if (contador) {
            const totalPrendas = carrito.reduce((total, item) => total + item.cantidad, 0);
            contador.innerText = totalPrendas;
        }
    }

    // --- FUNCIONES PARA ABRIR Y CERRAR LA VENTANA MODAL ---
    function abrirModalCarrito() {
        const modal = document.getElementById('modal-carrito');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        renderizarItemsCarrito();
    }

    function cerrarModalCarrito() {
        const modal = document.getElementById('modal-carrito');
        modal.classList.remove('flex');
        modal.classList.add('hidden');
    }

    // --- RENDERIZAR LA LISTA CON BOTONES + Y - ---
        function renderizarItemsCarrito() {
            const contenedor = document.getElementById('lista-carrito-items');
            const txtTotal = document.getElementById('total-carrito-dinero');
            
            if (carrito.length === 0) {
                contenedor.innerHTML = `<div class="text-center py-8 text-slate-400 font-medium flex flex-col items-center gap-2"><span>🛍️</span><span>Tu carrito está vacío.</span></div>`;
                txtTotal.innerText = "$0.00";
                return;
            }

            let html = '';
            let granTotal = 0;
            carrito.forEach((item, index) => {
                const subtotal = item.precio * item.cantidad;
                granTotal += subtotal;
                
                // 📷 CORRECCIÓN: Si no hay ruta guardada, cargamos por defecto tu logo local en lugar de pedir una URL externa
                const fotoUrl = item.imagenUrl || '/logo2.png';
                
                html += `
                <div class="flex items-center justify-between py-3 first:pt-0 gap-3">
                    <!-- 📷 El disparador onerror ahora también llama a tu logo local, eliminando las peticiones bloqueadas por CORB -->
                    <img src="${fotoUrl}" class="w-12 h-12 object-cover rounded-lg border border-slate-100 bg-slate-50 flex-shrink-0" onerror="this.src='/logo2.png'">
                    
                    <div class="flex-1 min-w-0">
                        <h4 class="font-bold text-slate-900 text-sm leading-tight truncate">${item.nombre}</h4>
                        <span class="text-xs text-slate-400 block mt-0.5">$${item.precio} c/u</span>
                    </div>
                    <div class="flex items-center gap-3 flex-shrink-0">
                        <div class="flex items-center border border-slate-200 rounded-lg bg-slate-50 overflow-hidden">
                            <button onclick="cambiarCantidad(${index}, -1)" class="px-2.5 py-1 text-slate-500 hover:bg-slate-200 font-bold transition text-sm">-</button>
                            <span class="px-2 font-black text-slate-800 text-sm">${item.cantidad}</span>
                            <button onclick="cambiarCantidad(${index}, 1)" class="px-2.5 py-1 text-slate-500 hover:bg-slate-200 font-bold transition text-sm">+</button>
                        </div>
                        <span class="text-sm font-black text-slate-900 w-16 text-right">$${subtotal.toFixed(2)}</span>
                    </div>
                </div>`;
            });
            contenedor.innerHTML = html;
            txtTotal.innerText = `$${granTotal.toFixed(2)}`;
        }


    function cambiarCantidad(index, cambio) {
        carrito[index].cantidad += cambio;
        // Si la cantidad llega a 0, eliminamos la prenda por completo del arreglo
        if (carrito[index].cantidad <= 0) {
            carrito.splice(index, 1);
        }
        guardarCarritoYActualizar();
    }

       // --- ENVIAR NOTIFICACIÓN CON EL PEDIDO EN TEXTO LIMPIO A WHATSAPP ---
        // --- ENVIAR NOTIFICACIÓN CON EL PEDIDO EN TEXTO LIMPIO A WHATSAPP ---
        // --- ENVIAR NOTIFICACIÓN CON EL PEDIDO EN TEXTO LIMPIO A WHATSAPP ---
    function enviarPedidoWhatsApp() {
        if (carrito.length === 0) return alert('Agrega productos primero antes de hacer tu pedido.');
        
        // Tu número de celular está perfecto aquí
        const miTelefono = "522216050287"; 
        
        let mensaje = `🛍️ *NUEVO PEDIDO - TRENDY COLORS*\n`;
        mensaje += `=========================\n\n`;
        
        let total = 0;
        carrito.forEach(item => {
            const subtotal = item.precio * item.cantidad;
            total += subtotal;
            mensaje += `🔹 *${item.cantidad}x* ${item.nombre} - _$${item.precio} c/u_\n`;
            mensaje += `   *Subtotal:* $${subtotal.toFixed(2)}\n\n`;
        });
        
        mensaje += `=========================\n`;
        mensaje += `💰 *TOTAL A PAGAR:* $${total.toFixed(2)}\n\n`;
        mensaje += `¿Me podrían confirmar disponibilidad, por favor? ✨`;

        // 🟢 CORRECCIÓN REAL: Ya lleva la diagonal después del .me/ para que el enlace sea válido
        const urlWhatsApp = "https://wa.me/" + miTelefono + "?text=" + encodeURIComponent(mensaje);
        
        // Abre la pestaña de WhatsApp de golpe en tu Chrome
        window.open(urlWhatsApp, '_blank');
    }


</script>



