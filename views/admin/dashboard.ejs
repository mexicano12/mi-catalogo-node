<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel de Administración</title>
    <!-- EL CORRETO: Con cdn. al principio para que pinte hermoso -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 p-6 md:p-12">
    <div class="max-w-6xl mx-auto bg-white p-6 md:p-8 rounded-xl shadow-md border border-gray-100">
        <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-8 border-b pb-6">
            <div>
                <h1 class="text-2xl font-bold text-gray-800">Administrador de Productos</h1>
                <p class="text-sm text-gray-500">Gestiona las prendas de tu catálogo</p>
            </div>
            <div class="flex gap-2">
                <a href="/admin/productos/crear" class="bg-blue-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-blue-700 transition">＋ Nuevo Producto</a>
                <a href="/admin/logout" class="bg-gray-200 text-gray-700 px-4 py-2 rounded-lg font-medium hover:bg-gray-300 transition">Salir</a>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50 border-b border-gray-200 text-gray-600 text-sm font-semibold uppercase">
                        <th class="p-4">Imagen</th>
                        <th class="p-4">Nombre</th>
                        <th class="p-4">Categoría</th>
                        <th class="p-4">Precio</th>
                        <th class="p-4 text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 text-gray-700">
                    <% productos.forEach(prod => { %>
                        <tr class="hover:bg-gray-50 transition">
                            <td class="p-4">
                                <img src="<%= prod.imagenUrl %>" class="w-12 h-12 object-cover rounded-lg border bg-gray-100" onerror="this.src='https://placehold.co'">
                            </td>
                            <td class="p-4 font-bold text-gray-900"><%= prod.nombre %></td>
                            <td class="p-4"><span class="bg-pink-50 text-pink-700 text-xs px-2 py-1 rounded-full font-semibold uppercase"><%= prod.categoria.nombre %></span></td>
                            <td class="p-4 text-green-600 font-extrabold">$<%= prod.precio %></td>
                            <td class="p-4 text-center">
                                <a href="/admin/productos/eliminar/<%= prod.id %>" onclick="return confirm('¿Seguro que deseas eliminar esta prenda del catálogo?')" class="text-red-600 hover:text-red-900 font-medium transition">Eliminar</a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>
