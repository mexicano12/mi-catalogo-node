<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Añadir Prenda Nueva</title>
    <!-- El enlace CDN real de producción -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen flex items-center justify-center p-4">
    <div class="bg-white p-8 rounded-xl shadow-md w-full max-w-lg border border-gray-100">
        <h2 class="text-2xl font-bold text-gray-800 mb-2">Nueva Prenda</h2>
        <p class="text-sm text-gray-500 mb-6">Completa los campos para añadir un producto al catálogo público</p>
        
        <!-- CAMBIO 1: Se agregó enctype="multipart/form-data" para permitir el envío de archivos físicos -->
        <form action="/admin/productos/crear" method="POST" enctype="multipart/form-data" class="space-y-4">
            <div>
                <label class="block text-gray-700 text-sm font-semibold mb-1">Nombre del artículo</label>
                <input type="text" name="nombre" required placeholder="Ej: Vestido Largo Elegante" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-pink-500 transition-all">
            </div>
            
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-gray-700 text-sm font-semibold mb-1">Precio ($ MXN)</label>
                    <input type="number" step="0.01" name="precio" required placeholder="399.00" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-pink-500 transition-all">
                </div>
                <div>
                    <label class="block text-gray-700 text-sm font-semibold mb-1">Categoría</label>
                    <select name="categoriaId" required class="w-full px-3 py-2.5 border border-gray-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-pink-500 transition-all">
                        <% categorias.forEach(cat => { %>
                            <option value="<%= cat.id %>"><%= cat.nombre %></option>
                        <% }) %>
                    </select>
                </div>
            </div>

            <div>
                <!-- CAMBIO 2: Se cambió de "url" a "file" con name="imagen" para conectar con Multer -->
                <label class="block text-gray-700 text-sm font-semibold mb-1">Foto del producto (Desde tu Mac)</label>
                <input type="file" name="imagen" accept="image/*" required class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-pink-50 file:text-pink-700 hover:file:bg-pink-100 cursor-pointer border border-gray-300 p-2 rounded-lg">
            </div>

            <div>
                <label class="block text-gray-700 text-sm font-semibold mb-1">Descripción de la prenda</label>
                <textarea name="descripcion" rows="3" required placeholder="Detalla la tela, tallas disponibles y colores..." class="w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-pink-500 transition-all"></textarea>
            </div>

            <div class="flex gap-3 pt-2">
                <button type="submit" class="flex-1 bg-pink-600 text-white py-2.5 rounded-lg font-semibold hover:bg-pink-700 transition shadow active:scale-[0.98]">Guardar Producto</button>
                <a href="/admin/dashboard" class="px-4 py-2.5 bg-gray-100 text-gray-700 border border-gray-200 rounded-lg font-semibold hover:bg-gray-200 text-center transition">Cancelar</a>
            </div>
        </form>
    </div>
</body>
</html>
